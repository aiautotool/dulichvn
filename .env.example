EXPO_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google OAuth client IDs. The Android/Web values below come from google-services.json.
# For production native builds, create OAuth clients that match app.json android.package / ios.bundleIdentifier.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=959396812028-5uedsvgcclv8ngjs97enll5tlmld45oa.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=959396812028-kebdshs109pum50s7of7eqe27odlgh3l.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# Optional backend endpoint. The bundled Cloudflare Worker exposes this after deploy.
EXPO_PUBLIC_ITINERARY_EMAIL_ENDPOINT=/api/itinerary-email

# Optional local deploy file: copy these to .env.cloudflare.local.
# Never commit real Cloudflare credentials.
CLOUDFLARE_EMAIL=info@aiautotool.com
CLOUDFLARE_API_KEY=your-global-api-key
